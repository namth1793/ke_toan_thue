# Copy file này thành .env và điền giá trị thực

PORT=5013
NODE_ENV=production

# Netlify URL của frontend (dùng để whitelist CORS)
# Ví dụ: https://sorata-advisory.netlify.app
# Nhiều domain cách nhau bằng dấu phẩy
CORS_ORIGIN=https://your-site.netlify.app

# JWT Secret - đặt chuỗi ngẫu nhiên dài, bí mật
JWT_SECRET=your-secret-key-here

# Cloudinary (để upload ảnh trong admin panel)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
